{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["jest", "node", "multer"]
  },
  "include": ["emulator.ts", "triggers/*.ts", "tests/*/*.ts"],
  "exclude": ["node_modules", "dist", "utils/**/*"]
}
